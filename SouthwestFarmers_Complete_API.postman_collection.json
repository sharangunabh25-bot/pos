{
  "info": {
    "name": "Southwest Farmers POS — Complete Hardware API",
    "_postman_id": "swf-complete-hardware-api",
    "description": "All hardware-service endpoints in one collection.\n\nSet these collection variables before use:\n  local_url    = http://localhost:3001\n  cloud_url    = https://pos-02fj.onrender.com\n  terminal_id  = your terminal UID (from config.json)\n  agent_secret = your agent secret (from config.json)\n  store_id     = your store ID",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "local_url",    "value": "http://localhost:3001",          "type": "string" },
    { "key": "cloud_url",   "value": "https://pos-02fj.onrender.com",  "type": "string" },
    { "key": "terminal_id", "value": "REPLACE_WITH_TERMINAL_UID",      "type": "string" },
    { "key": "agent_secret","value": "REPLACE_WITH_AGENT_SECRET",      "type": "string" },
    { "key": "store_id",    "value": "REPLACE_WITH_STORE_ID",          "type": "string" },
    { "key": "ref_num",     "value": "",                               "type": "string" }
  ],
  "item": [

    {
      "name": "🖥️ LOCAL (localhost:3001)",
      "description": "Call these directly from the POS machine. Requires x-terminal-id + x-agent-secret headers.",
      "item": [

        {
          "name": "🔖 Terminal",
          "item": [
            {
              "name": "Who Am I (public)",
              "request": {
                "method": "GET",
                "header": [],
                "url": { "raw": "{{local_url}}/api/terminal/whoami", "host": ["{{local_url}}"], "path": ["api","terminal","whoami"] },
                "description": "No auth needed. Returns terminal UID, store, hostname, approval status."
              }
            },
            {
              "name": "Terminal Status",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "x-terminal-id",  "value": "{{terminal_id}}" },
                  { "key": "x-agent-secret", "value": "{{agent_secret}}" }
                ],
                "url": { "raw": "{{local_url}}/api/terminal/status", "host": ["{{local_url}}"], "path": ["api","terminal","status"] },
                "description": "Returns uptime, approval, registration, hostname."
              }
            },
            {
              "name": "Register Terminal",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "x-terminal-id",  "value": "{{terminal_id}}" },
                  { "key": "x-agent-secret", "value": "{{agent_secret}}" },
                  { "key": "Content-Type",   "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"terminal_id\": \"{{terminal_id}}\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": { "raw": "{{local_url}}/api/terminal/register", "host": ["{{local_url}}"], "path": ["api","terminal","register"] }
              }
            },
            {
              "name": "Approve Terminal",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "x-terminal-id",  "value": "{{terminal_id}}" },
                  { "key": "x-agent-secret", "value": "{{agent_secret}}" },
                  { "key": "Content-Type",   "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"store_id\": \"{{store_id}}\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": { "raw": "{{local_url}}/api/terminal/approve", "host": ["{{local_url}}"], "path": ["api","terminal","approve"] }
              }
            }
          ]
        },

        {
          "name": "💳 Payment (PAX A35)",
          "item": [
            {
              "name": "Elavon Config",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "x-terminal-id",  "value": "{{terminal_id}}" },
                  { "key": "x-agent-secret", "value": "{{agent_secret}}" }
                ],
                "url": { "raw": "{{local_url}}/api/payment/elavon-config", "host": ["{{local_url}}"], "path": ["api","payment","elavon-config"] },
                "description": "Returns TID, MID, Elavon host/port."
              }
            },
            {
              "name": "Status (Ping Terminal)",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "x-terminal-id",  "value": "{{terminal_id}}" },
                  { "key": "x-agent-secret", "value": "{{agent_secret}}" }
                ],
                "url": { "raw": "{{local_url}}/api/payment/status", "host": ["{{local_url}}"], "path": ["api","payment","status"] },
                "description": "Sends A00 Initialize to PAX A35 at 192.168.1.44:10009."
              }
            },
            {
              "name": "Initiate Sale",
              "event": [{ "listen": "test", "script": { "exec": ["var j=pm.response.json(); if(j.refNum) pm.collectionVariables.set('ref_num',j.refNum);"], "type": "text/javascript" } }],
              "request": {
                "method": "POST",
                "header": [
                  { "key": "x-terminal-id",  "value": "{{terminal_id}}" },
                  { "key": "x-agent-secret", "value": "{{agent_secret}}" },
                  { "key": "Content-Type",   "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"amount\": 1.00,\n  \"currency\": \"USD\",\n  \"order_id\": \"ORD-001\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": { "raw": "{{local_url}}/api/payment/initiate", "host": ["{{local_url}}"], "path": ["api","payment","initiate"] },
                "description": "T00 Sale. Saves refNum to collection variable automatically."
              }
            },
            {
              "name": "Cancel (Abort)",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "x-terminal-id",  "value": "{{terminal_id}}" },
                  { "key": "x-agent-secret", "value": "{{agent_secret}}" },
                  { "key": "Content-Type",   "value": "application/json" }
                ],
                "body": { "mode": "raw", "raw": "{}", "options": { "raw": { "language": "json" } } },
                "url": { "raw": "{{local_url}}/api/payment/cancel", "host": ["{{local_url}}"], "path": ["api","payment","cancel"] },
                "description": "A14 Abort — cancels in-progress transaction on the terminal."
              }
            },
            {
              "name": "Void Transaction",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "x-terminal-id",  "value": "{{terminal_id}}" },
                  { "key": "x-agent-secret", "value": "{{agent_secret}}" },
                  { "key": "Content-Type",   "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"ref_num\": \"{{ref_num}}\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": { "raw": "{{local_url}}/api/payment/void", "host": ["{{local_url}}"], "path": ["api","payment","void"] },
                "description": "T02 Void. ref_num comes from initiate response (auto-saved)."
              }
            },
            {
              "name": "Refund Transaction",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "x-terminal-id",  "value": "{{terminal_id}}" },
                  { "key": "x-agent-secret", "value": "{{agent_secret}}" },
                  { "key": "Content-Type",   "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"amount\": 1.00,\n  \"ref_num\": \"{{ref_num}}\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": { "raw": "{{local_url}}/api/payment/refund", "host": ["{{local_url}}"], "path": ["api","payment","refund"] },
                "description": "T04 Return. Amount in dollars."
              }
            }
          ]
        },

        {
          "name": "💵 Cash Drawer",
          "item": [
            {
              "name": "Status",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "x-terminal-id",  "value": "{{terminal_id}}" },
                  { "key": "x-agent-secret", "value": "{{agent_secret}}" }
                ],
                "url": { "raw": "{{local_url}}/api/cash-drawer/status", "host": ["{{local_url}}"], "path": ["api","cash-drawer","status"] },
                "description": "Checks if COM5 serial path is configured."
              }
            },
            {
              "name": "Open Drawer",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "x-terminal-id",  "value": "{{terminal_id}}" },
                  { "key": "x-agent-secret", "value": "{{agent_secret}}" },
                  { "key": "Content-Type",   "value": "application/json" }
                ],
                "body": { "mode": "raw", "raw": "{}", "options": { "raw": { "language": "json" } } },
                "url": { "raw": "{{local_url}}/api/cash-drawer/open", "host": ["{{local_url}}"], "path": ["api","cash-drawer","open"] },
                "description": "Opens the M-S CF-405BX cash drawer via serial (COM5)."
              }
            }
          ]
        },

        {
          "name": "🖨️ Printer",
          "item": [
            {
              "name": "List Printers",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "x-terminal-id",  "value": "{{terminal_id}}" },
                  { "key": "x-agent-secret", "value": "{{agent_secret}}" }
                ],
                "url": { "raw": "{{local_url}}/api/printer/list", "host": ["{{local_url}}"], "path": ["api","printer","list"] },
                "description": "Lists all Windows printers visible to this terminal."
              }
            },
            {
              "name": "Print Receipt",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "x-terminal-id",  "value": "{{terminal_id}}" },
                  { "key": "x-agent-secret", "value": "{{agent_secret}}" },
                  { "key": "Content-Type",   "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"store_name\": \"Southwest Farmers\",\n  \"cashier\": \"John\",\n  \"order_id\": \"ORD-001\",\n  \"items\": [\n    { \"name\": \"Apple\",  \"qty\": 2, \"price\": 1.50 },\n    { \"name\": \"Banana\", \"qty\": 3, \"price\": 0.75 }\n  ],\n  \"total\": 5.25,\n  \"payment_method\": \"CARD\",\n  \"auth_code\": \"TAS123\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": { "raw": "{{local_url}}/api/printer/print", "host": ["{{local_url}}"], "path": ["api","printer","print"] },
                "description": "Prints a receipt. items[].qty and price must be numbers."
              }
            }
          ]
        },

        {
          "name": "⚖️ Scale",
          "item": [
            {
              "name": "Status",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "x-terminal-id",  "value": "{{terminal_id}}" },
                  { "key": "x-agent-secret", "value": "{{agent_secret}}" }
                ],
                "url": { "raw": "{{local_url}}/api/scale/status", "host": ["{{local_url}}"], "path": ["api","scale","status"] }
              }
            },
            {
              "name": "Get Weight",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "x-terminal-id",  "value": "{{terminal_id}}" },
                  { "key": "x-agent-secret", "value": "{{agent_secret}}" }
                ],
                "url": { "raw": "{{local_url}}/api/scale/weight", "host": ["{{local_url}}"], "path": ["api","scale","weight"] },
                "description": "Returns last weight reading in kg from the scale (COM3)."
              }
            }
          ]
        },

        {
          "name": "📷 Scanner (Zebra DS2278)",
          "item": [
            {
              "name": "Status",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "x-terminal-id",  "value": "{{terminal_id}}" },
                  { "key": "x-agent-secret", "value": "{{agent_secret}}" }
                ],
                "url": { "raw": "{{local_url}}/api/scanner/status", "host": ["{{local_url}}"], "path": ["api","scanner","status"] }
              }
            },
            {
              "name": "Last Scan",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "x-terminal-id",  "value": "{{terminal_id}}" },
                  { "key": "x-agent-secret", "value": "{{agent_secret}}" }
                ],
                "url": { "raw": "{{local_url}}/api/scanner/last", "host": ["{{local_url}}"], "path": ["api","scanner","last"] },
                "description": "Returns the most recently scanned barcode."
              }
            },
            {
              "name": "Simulate Scan (Testing)",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "x-terminal-id",  "value": "{{terminal_id}}" },
                  { "key": "x-agent-secret", "value": "{{agent_secret}}" },
                  { "key": "Content-Type",   "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"value\": \"1234567890128\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": { "raw": "{{local_url}}/api/scanner/simulate", "host": ["{{local_url}}"], "path": ["api","scanner","simulate"] },
                "description": "Injects a barcode as if physically scanned. For testing without the physical scanner."
              }
            }
          ]
        }

      ]
    },

    {
      "name": "☁️ CLOUD (Render)",
      "description": "Call these from any remote frontend/server. Requires x-store-id header. Cloud forwards to the active hardware terminal.",
      "item": [

        {
          "name": "💳 Payment (PAX A35)",
          "item": [
            {
              "name": "Elavon Config",
              "request": {
                "method": "GET",
                "header": [{ "key": "x-store-id", "value": "{{store_id}}" }],
                "url": { "raw": "{{cloud_url}}/api/payment/elavon-config", "host": ["{{cloud_url}}"], "path": ["api","payment","elavon-config"] }
              }
            },
            {
              "name": "Status",
              "request": {
                "method": "GET",
                "header": [{ "key": "x-store-id", "value": "{{store_id}}" }],
                "url": { "raw": "{{cloud_url}}/api/payment/status", "host": ["{{cloud_url}}"], "path": ["api","payment","status"] }
              }
            },
            {
              "name": "Initiate Sale",
              "event": [{ "listen": "test", "script": { "exec": ["var j=pm.response.json(); if(j.refNum) pm.collectionVariables.set('ref_num',j.refNum);"], "type": "text/javascript" } }],
              "request": {
                "method": "POST",
                "header": [{ "key": "x-store-id", "value": "{{store_id}}" }, { "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"amount\": 1.00,\n  \"currency\": \"USD\",\n  \"order_id\": \"ORD-001\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": { "raw": "{{cloud_url}}/api/payment/initiate", "host": ["{{cloud_url}}"], "path": ["api","payment","initiate"] }
              }
            },
            {
              "name": "Cancel (Abort)",
              "request": {
                "method": "POST",
                "header": [{ "key": "x-store-id", "value": "{{store_id}}" }, { "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{}", "options": { "raw": { "language": "json" } } },
                "url": { "raw": "{{cloud_url}}/api/payment/cancel", "host": ["{{cloud_url}}"], "path": ["api","payment","cancel"] }
              }
            },
            {
              "name": "Void Transaction",
              "request": {
                "method": "POST",
                "header": [{ "key": "x-store-id", "value": "{{store_id}}" }, { "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"ref_num\": \"{{ref_num}}\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": { "raw": "{{cloud_url}}/api/payment/void", "host": ["{{cloud_url}}"], "path": ["api","payment","void"] }
              }
            },
            {
              "name": "Refund Transaction",
              "request": {
                "method": "POST",
                "header": [{ "key": "x-store-id", "value": "{{store_id}}" }, { "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"amount\": 1.00,\n  \"ref_num\": \"{{ref_num}}\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": { "raw": "{{cloud_url}}/api/payment/refund", "host": ["{{cloud_url}}"], "path": ["api","payment","refund"] }
              }
            }
          ]
        },

        {
          "name": "💵 Cash Drawer",
          "item": [
            {
              "name": "Status",
              "request": {
                "method": "GET",
                "header": [{ "key": "x-store-id", "value": "{{store_id}}" }],
                "url": { "raw": "{{cloud_url}}/api/cash-drawer/status", "host": ["{{cloud_url}}"], "path": ["api","cash-drawer","status"] }
              }
            },
            {
              "name": "Open Drawer",
              "request": {
                "method": "POST",
                "header": [{ "key": "x-store-id", "value": "{{store_id}}" }, { "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{}", "options": { "raw": { "language": "json" } } },
                "url": { "raw": "{{cloud_url}}/api/cash-drawer/open", "host": ["{{cloud_url}}"], "path": ["api","cash-drawer","open"] }
              }
            }
          ]
        },

        {
          "name": "🖨️ Printer",
          "item": [
            {
              "name": "List Printers",
              "request": {
                "method": "GET",
                "header": [{ "key": "x-store-id", "value": "{{store_id}}" }],
                "url": { "raw": "{{cloud_url}}/api/printer/list", "host": ["{{cloud_url}}"], "path": ["api","printer","list"] }
              }
            },
            {
              "name": "Print Receipt",
              "request": {
                "method": "POST",
                "header": [{ "key": "x-store-id", "value": "{{store_id}}" }, { "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"store_name\": \"Southwest Farmers\",\n  \"cashier\": \"John\",\n  \"order_id\": \"ORD-001\",\n  \"items\": [\n    { \"name\": \"Apple\",  \"qty\": 2, \"price\": 1.50 },\n    { \"name\": \"Banana\", \"qty\": 3, \"price\": 0.75 }\n  ],\n  \"total\": 5.25,\n  \"payment_method\": \"CARD\",\n  \"auth_code\": \"TAS123\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": { "raw": "{{cloud_url}}/api/printer/print", "host": ["{{cloud_url}}"], "path": ["api","printer","print"] }
              }
            },
            {
              "name": "Heartbeat (hardware → cloud)",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "x-terminal-id",  "value": "{{terminal_id}}" },
                  { "key": "x-agent-secret", "value": "{{agent_secret}}" },
                  { "key": "Content-Type",   "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"store_id\": \"{{store_id}}\",\n  \"hardware_url\": \"http://YOUR_NGROK_URL\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": { "raw": "{{cloud_url}}/api/printer/heartbeat", "host": ["{{cloud_url}}"], "path": ["api","printer","heartbeat"] },
                "description": "Sent by hardware agent to register its ngrok URL with the cloud. Auto-sent every 30s normally."
              }
            }
          ]
        },

        {
          "name": "⚖️ Scale",
          "item": [
            {
              "name": "Status",
              "request": {
                "method": "GET",
                "header": [{ "key": "x-store-id", "value": "{{store_id}}" }],
                "url": { "raw": "{{cloud_url}}/api/scale/status", "host": ["{{cloud_url}}"], "path": ["api","scale","status"] }
              }
            },
            {
              "name": "Get Weight",
              "request": {
                "method": "GET",
                "header": [{ "key": "x-store-id", "value": "{{store_id}}" }],
                "url": { "raw": "{{cloud_url}}/api/scale/weight", "host": ["{{cloud_url}}"], "path": ["api","scale","weight"] }
              }
            }
          ]
        },

        {
          "name": "📷 Scanner",
          "item": [
            {
              "name": "Status",
              "request": {
                "method": "GET",
                "header": [{ "key": "x-store-id", "value": "{{store_id}}" }],
                "url": { "raw": "{{cloud_url}}/api/scanner/status", "host": ["{{cloud_url}}"], "path": ["api","scanner","status"] }
              }
            },
            {
              "name": "Last Scan",
              "request": {
                "method": "GET",
                "header": [{ "key": "x-store-id", "value": "{{store_id}}" }],
                "url": { "raw": "{{cloud_url}}/api/scanner/last", "host": ["{{cloud_url}}"], "path": ["api","scanner","last"] }
              }
            },
            {
              "name": "Simulate Scan (Testing)",
              "request": {
                "method": "POST",
                "header": [{ "key": "x-store-id", "value": "{{store_id}}" }, { "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"value\": \"1234567890128\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": { "raw": "{{cloud_url}}/api/scanner/simulate", "host": ["{{cloud_url}}"], "path": ["api","scanner","simulate"] }
              }
            }
          ]
        },

        {
          "name": "🔖 Cloud Heartbeat",
          "item": [
            {
              "name": "Register Terminal Heartbeat",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "x-agent-secret", "value": "{{agent_secret}}" },
                  { "key": "Content-Type",   "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"terminal_uid\": \"{{terminal_id}}\",\n  \"store_id\": \"{{store_id}}\",\n  \"ip\": \"YOUR_NGROK_URL\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": { "raw": "{{cloud_url}}/api/cloud/heartbeat", "host": ["{{cloud_url}}"], "path": ["api","cloud","heartbeat"] },
                "description": "Registers the hardware agent's URL with the cloud. Sent automatically by local-agent.js every 30s."
              }
            }
          ]
        }

      ]
    }

  ]
}
